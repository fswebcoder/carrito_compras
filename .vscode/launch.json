{
    "version": "0.2.0",
    "configurations": [
        // ============================================
        // LOCAL ENVIRONMENT (default .env)
        // ============================================
        {
            "name": "🏠 Local - Windows",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "flutterMode": "debug",
            "deviceId": "windows",
            "toolArgs": [
                "--dart-define=ENV=local"
            ]
        },
        {
            "name": "🏠 Local - Edge",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "flutterMode": "debug",
            "deviceId": "edge",
            "toolArgs": [
                "--dart-define=ENV=local"
            ]
        },
        {
            "name": "🏠 Local - Web Server",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "flutterMode": "debug",
            "deviceId": "web-server",
            "toolArgs": [
                "--dart-define=ENV=local",
                "--web-port=5000"
            ]
        },
        {
            "name": "🏠 Local - Chrome",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "flutterMode": "debug",
            "deviceId": "chrome",
            "toolArgs": [
                "--dart-define=ENV=local"
            ]
        },
        {
            "name": "🏠 Local - Android Emulator",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "flutterMode": "debug",
            "preLaunchTask": "logcat:filtered",
            "toolArgs": [
                "--dart-define=ENV=local"
            ]
        },
